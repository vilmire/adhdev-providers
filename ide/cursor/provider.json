{
  "type": "cursor",
  "name": "Cursor",
  "category": "ide",
  "displayName": "Cursor",
  "icon": "⚡",
  "cli": "cursor",
  "cdpPorts": [
    9333,
    9334
  ],
  "targetFilter": {
    "urlIncludes": "workbench.html",
    "urlExcludes": [
      "agent"
    ],
    "titleExcludes": "extension-output|ADHDev CDP|Debug Console|Output\\s*$|Launchpad"
  },
  "processNames": {
    "darwin": "Cursor",
    "win32": [
      "Cursor.exe"
    ]
  },
  "paths": {
    "darwin": [
      "/Applications/Cursor.app"
    ],
    "win32": [
      "C:\\Users\\*\\AppData\\Local\\Programs\\cursor\\Cursor.exe"
    ],
    "linux": [
      "/opt/Cursor",
      "/usr/share/cursor"
    ]
  },
  "inputMethod": "cdp-type-and-send",
  "inputSelector": ".aislash-editor-input[contenteditable=\"true\"]",
  "versionCommand": "cursor --version",
  "providerVersion": "1.0.0",
  "compatibility": [
    {
      "ideVersion": ">=1.0.0",
      "scriptDir": "scripts/1.0"
    }
  ],
  "defaultScriptDir": "scripts/1.0",
  "vscodeCommands": {
    "changeModel": "cursor.model"
  },
  "settings": {
    "approvalAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Approval Notifications",
      "description": "Show notification when approval is needed"
    },
    "longGeneratingAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Long Generation Alert",
      "description": "Alert when generation takes too long"
    },
    "longGeneratingThresholdSec": {
      "type": "number",
      "default": 180,
      "public": true,
      "label": "Long Generation Threshold (sec)",
      "min": 30,
      "max": 600
    }
  },
  "status": "Stable",
  "details": "Full CDP support",
  "contractVersion": 2,
  "controls": [
    {
      "id": "model",
      "type": "select",
      "label": "Model",
      "icon": "🤖",
      "placement": "bar",
      "order": 10,
      "dynamic": true,
      "listScript": "listModels",
      "setScript": "setModel",
      "readFrom": "model"
    },
    {
      "id": "mode",
      "type": "select",
      "label": "Mode",
      "icon": "🧭",
      "placement": "bar",
      "order": 20,
      "dynamic": true,
      "listScript": "listModes",
      "setScript": "setMode",
      "readFrom": "mode"
    },
    {
      "id": "new_session",
      "type": "action",
      "label": "New",
      "icon": "➕",
      "placement": "bar",
      "order": 80,
      "invokeScript": "newSession"
    }
  ]
}
