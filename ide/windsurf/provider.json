{
  "type": "windsurf",
  "name": "Windsurf",
  "category": "ide",
  "displayName": "Windsurf",
  "icon": "\ud83c\udfc4",
  "cli": "windsurf",
  "cdpPorts": [
    9337,
    9338
  ],
  "targetFilter": {
    "urlIncludes": "workbench.html",
    "urlExcludes": [
      "agent"
    ],
    "titleExcludes": "extension-output|ADHDev CDP|Debug Console|Output\\s*$|Launchpad"
  },
  "processNames": {
    "darwin": "Windsurf"
  },
  "paths": {
    "darwin": [
      "/Applications/Windsurf.app"
    ]
  },
  "versionCommand": "windsurf --version",
  "providerVersion": "1.0.0",
  "compatibility": [
    {
      "ideVersion": ">=1.0.0",
      "scriptDir": "scripts/1.0"
    }
  ],
  "defaultScriptDir": "scripts/1.0",
  "settings": {
    "approvalAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Approval Notifications",
      "description": "Show notification when approval is needed"
    },
    "longGeneratingAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Long Generation Alert",
      "description": "Alert when generation takes too long"
    },
    "longGeneratingThresholdSec": {
      "type": "number",
      "default": 180,
      "public": true,
      "label": "Long Generation Threshold (sec)",
      "min": 30,
      "max": 600
    }
  },
  "status": "Stable",
  "details": "Full CDP support",
  "contractVersion": 2,
  "controls": [
    {
      "id": "model",
      "type": "select",
      "label": "Model",
      "icon": "\ud83e\udd16",
      "placement": "bar",
      "order": 10,
      "dynamic": true,
      "listScript": "listModels",
      "setScript": "setModel",
      "readFrom": "model"
    },
    {
      "id": "mode",
      "type": "select",
      "label": "Mode",
      "icon": "\ud83e\udded",
      "placement": "bar",
      "order": 20,
      "dynamic": true,
      "listScript": "listModes",
      "setScript": "setMode",
      "readFrom": "mode"
    },
    {
      "id": "new_session",
      "type": "action",
      "label": "New",
      "icon": "\u2795",
      "placement": "bar",
      "order": 80,
      "invokeScript": "newSession"
    }
  ],
  "capabilities": {
    "input": {
      "multipart": false,
      "mediaTypes": [
        "text"
      ]
    },
    "output": {
      "richContent": false,
      "mediaTypes": [
        "text"
      ]
    },
    "controls": {
      "typedResults": true
    }
  }
}
