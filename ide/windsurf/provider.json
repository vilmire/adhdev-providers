{
  "type": "windsurf",
  "name": "Windsurf",
  "category": "ide",
  "displayName": "Windsurf",
  "icon": "🏄",
  "cli": "windsurf",
  "cdpPorts": [
    9337,
    9338
  ],
  "targetFilter": {
    "urlIncludes": "workbench.html",
    "urlExcludes": [
      "agent"
    ],
    "titleExcludes": "extension-output|ADHDev CDP|Debug Console|Output\\s*$|Launchpad"
  },
  "processNames": {
    "darwin": "Windsurf"
  },
  "paths": {
    "darwin": [
      "/Applications/Windsurf.app"
    ]
  },
  "inputMethod": "cdp-type-and-send",
  "inputSelector": "[contenteditable=\"true\"][role=\"textbox\"]",
  "settings": {
    "approvalAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Approval Notifications",
      "description": "Show notification when approval is needed"
    },
    "longGeneratingAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Long Generation Alert",
      "description": "Alert when generation takes too long"
    },
    "longGeneratingThresholdSec": {
      "type": "number",
      "default": 180,
      "public": true,
      "label": "Long Generation Threshold (sec)",
      "min": 30,
      "max": 600
    }
  }
}
