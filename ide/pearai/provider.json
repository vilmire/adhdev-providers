{
  "type": "pearai",
  "name": "PearAI",
  "category": "ide",
  "displayName": "PearAI",
  "icon": "🍐",
  "cli": "pearai",
  "cdpPorts": [
    9355,
    9356
  ],
  "targetFilter": {
    "urlIncludes": "workbench.html",
    "urlExcludes": [
      "agent"
    ],
    "titleExcludes": "extension-output|ADHDev CDP|Debug Console|Output\\s*$|Launchpad"
  },
  "processNames": {
    "darwin": "PearAI",
    "win32": [
      "PearAI.exe"
    ],
    "linux": [
      "pearai"
    ]
  },
  "paths": {
    "darwin": [
      "/Applications/PearAI.app"
    ],
    "win32": [
      "C:\\Users\\*\\AppData\\Local\\Programs\\pearai\\PearAI.exe"
    ],
    "linux": [
      "/opt/pearai",
      "/usr/share/pearai"
    ]
  },
  "webviewMatchText": "chat-text-area",
  "versionCommand": "pearai --version",
  "providerVersion": "0.0.0",
  "compatibility": [
    {
      "ideVersion": ">=1.0.0",
      "scriptDir": "scripts/1.0"
    }
  ],
  "defaultScriptDir": "scripts/1.0",
  "settings": {
    "approvalAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Approval Notifications",
      "description": "Show notification when approval is needed"
    },
    "longGeneratingAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Long Generation Alert",
      "description": "Alert when generation takes too long"
    },
    "longGeneratingThresholdSec": {
      "type": "number",
      "default": 180,
      "public": true,
      "label": "Long Generation Threshold (sec)",
      "min": 30,
      "max": 600
    }
  },
  "status": "Beta",
  "details": "Webview CDP support",
  "contractVersion": 2,
  "controls": [
    {
      "id": "model",
      "type": "select",
      "label": "Model",
      "icon": "🤖",
      "placement": "bar",
      "order": 10,
      "dynamic": true,
      "listScript": "listModels",
      "setScript": "setModel",
      "readFrom": "model"
    },
    {
      "id": "mode",
      "type": "select",
      "label": "Mode",
      "icon": "🧭",
      "placement": "bar",
      "order": 20,
      "dynamic": true,
      "listScript": "listModes",
      "setScript": "setMode",
      "readFrom": "mode"
    },
    {
      "id": "new_session",
      "type": "action",
      "label": "New",
      "icon": "➕",
      "placement": "bar",
      "order": 80,
      "invokeScript": "newSession"
    }
  ]
}
