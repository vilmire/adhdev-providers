{
  "type": "antigravity",
  "name": "Antigravity",
  "category": "ide",
  "displayName": "Antigravity",
  "icon": "🚀",
  "cli": "antigravity",
  "launch": {
    "prefer": {
      "darwin": "app"
    }
  },
  "cdpPorts": [
    9335,
    9336
  ],
  "targetFilter": {
    "urlIncludes": "workbench.html",
    "urlExcludes": [
      "agent"
    ],
    "titleExcludes": "extension-output|ADHDev CDP|Debug Console|Output\\s*$|Launchpad"
  },
  "processNames": {
    "darwin": "Antigravity",
    "win32": [
      "Antigravity.exe"
    ]
  },
  "paths": {
    "darwin": [
      "/Applications/Antigravity.app"
    ],
    "win32": [
      "C:\\Users\\*\\AppData\\Local\\Programs\\antigravity\\Antigravity.exe"
    ],
    "linux": [
      "/opt/Antigravity",
      "/usr/share/antigravity"
    ]
  },
  "inputMethod": "cdp-type-and-send",
  "inputSelector": "[contenteditable=\"true\"][role=\"textbox\"]",
  "versionCommand": "antigravity --version",
  "providerVersion": "1.0.0",
  "compatibility": [
    {
      "ideVersion": ">=1.0.0",
      "scriptDir": "scripts/1.0"
    }
  ],
  "defaultScriptDir": "scripts/1.0",
  "settings": {
    "approvalAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Approval Notifications",
      "description": "Show notification when approval is needed"
    },
    "longGeneratingAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Long Generation Alert",
      "description": "Alert when generation takes too long"
    },
    "longGeneratingThresholdSec": {
      "type": "number",
      "default": 180,
      "public": true,
      "label": "Long Generation Threshold (sec)",
      "min": 30,
      "max": 600
    },
    "showThinking": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Show Thinking",
      "description": "Display AI thinking/reasoning process in chat"
    },
    "showToolCalls": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Show Tool Calls",
      "description": "Display tool call summaries (Searched, Analyzed, Edited, etc.)"
    },
    "showTerminal": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Show Terminal",
      "description": "Display terminal command execution and output"
    }
  },
  "status": "Stable",
  "details": "Full CDP support",
  "contractVersion": 2,
  "controls": [
    {
      "id": "model",
      "type": "select",
      "label": "Model",
      "icon": "🤖",
      "placement": "bar",
      "order": 10,
      "dynamic": true,
      "listScript": "listModels",
      "setScript": "setModel",
      "readFrom": "model"
    },
    {
      "id": "mode",
      "type": "select",
      "label": "Mode",
      "icon": "🧭",
      "placement": "bar",
      "order": 20,
      "dynamic": true,
      "listScript": "listModes",
      "setScript": "setMode",
      "readFrom": "mode"
    },
    {
      "id": "new_session",
      "type": "action",
      "label": "New",
      "icon": "➕",
      "placement": "bar",
      "hidden": true,
      "order": 80,
      "invokeScript": "newSession"
    }
  ],
  "capabilities": {
    "input": {
      "multipart": false,
      "mediaTypes": [
        "text"
      ]
    },
    "output": {
      "richContent": false,
      "mediaTypes": [
        "text"
      ]
    },
    "controls": {
      "typedResults": true
    }
  }
}
