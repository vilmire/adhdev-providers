{
  "type": "vscode",
  "name": "Visual Studio Code",
  "category": "ide",
  "displayName": "VS Code",
  "icon": "💙",
  "cli": "code",
  "cdpPorts": [
    9339,
    9340
  ],
  "spawn": {
    "command": "\"/Applications/Visual Studio Code.app/Contents/MacOS/Electron\"",
    "args": [
      "--remote-debugging-port=${PORT:-9339}",
      "--user-data-dir=${HOME}/.adhdev/test-profiles/vscode"
    ],
    "shell": true
  },
  "targetFilter": {
    "urlIncludes": "workbench.html",
    "urlExcludes": [
      "agent"
    ],
    "titleExcludes": "extension-output|ADHDev CDP|Debug Console|Output\\s*$|Launchpad"
  },
  "processNames": {
    "darwin": [
      "Code",
      "Electron",
      "Visual Studio Code"
    ],
    "win32": [
      "Code.exe"
    ]
  },
  "paths": {
    "darwin": [
      "/Applications/Visual Studio Code.app"
    ],
    "win32": [
      "C:\\Program Files\\Microsoft VS Code\\Code.exe",
      "C:\\Users\\*\\AppData\\Local\\Programs\\Microsoft VS Code\\Code.exe"
    ],
    "linux": [
      "/usr/share/code",
      "/snap/code/current"
    ]
  },
  "inputMethod": "cdp-type-and-send",
  "inputSelector": ".interactive-input-editor .native-edit-context[role=\"textbox\"]",
  "versionCommand": {
    "darwin": "\"/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code\" --version",
    "win32": "\"C:\\Program Files\\Microsoft VS Code\\bin\\code\" --version",
    "linux": "code --version"
  },
  "providerVersion": "1.0.0",
  "compatibility": [
    {
      "ideVersion": ">=1.0.0",
      "scriptDir": "scripts/1.0"
    }
  ],
  "defaultScriptDir": "scripts/1.0",
  "settings": {
    "approvalAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Approval Notifications",
      "description": "Show notification when approval is needed"
    },
    "longGeneratingAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Long Generation Alert",
      "description": "Alert when generation takes too long"
    },
    "longGeneratingThresholdSec": {
      "type": "number",
      "default": 180,
      "public": true,
      "label": "Long Generation Threshold (sec)",
      "min": 30,
      "max": 600
    }
  },
  "status": "WIP",
  "details": "Infrastructure ready"
}
