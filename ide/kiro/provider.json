{
  "type": "kiro",
  "name": "Kiro",
  "category": "ide",
  "displayName": "Kiro",
  "icon": "🪁",
  "cli": "kiro",
  "cdpPorts": [
    9351,
    9352
  ],
  "targetFilter": {
    "urlIncludes": "workbench.html",
    "urlExcludes": [
      "agent"
    ],
    "titleExcludes": "extension-output|ADHDev CDP|Debug Console|Output\\s*$|Launchpad"
  },
  "processNames": {
    "darwin": "Kiro",
    "win32": [
      "Kiro.exe"
    ],
    "linux": [
      "kiro"
    ]
  },
  "paths": {
    "darwin": [
      "/Applications/Kiro.app"
    ],
    "win32": [
      "C:\\Users\\*\\AppData\\Local\\Programs\\kiro\\Kiro.exe"
    ],
    "linux": [
      "/opt/kiro",
      "/usr/share/kiro"
    ]
  },
  "inputMethod": "cdp-type-and-send",
  "inputSelector": "[contenteditable=\"true\"][role=\"textbox\"]",
  "settings": {
    "approvalAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Approval Notifications",
      "description": "Show notification when approval is needed"
    },
    "longGeneratingAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Long Generation Alert",
      "description": "Alert when generation takes too long"
    },
    "longGeneratingThresholdSec": {
      "type": "number",
      "default": 180,
      "public": true,
      "label": "Long Generation Threshold (sec)",
      "min": 30,
      "max": 600
    }
  },
  "defaultScriptDir": "scripts/1.0",
  "compatibility": []
}