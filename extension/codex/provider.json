{
  "type": "codex",
  "name": "Codex",
  "category": "extension",
  "extensionId": "openai.chatgpt",
  "extensionIdPattern": "extensionId=openai\\.chat",
  "extensionIdPattern_flags": "i",
  "webviewMatchText": "openai.chat",
  "vscodeCommands": {
    "focusPanel": "openai-chatgpt.focus"
  },
  "settings": {
    "approvalAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Approval Notifications",
      "description": "Show notification when approval is needed"
    },
    "longGeneratingAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Long Generation Alert",
      "description": "Alert when generation takes too long"
    },
    "longGeneratingThresholdSec": {
      "type": "number",
      "default": 180,
      "public": true,
      "label": "Long Generation Threshold (sec)",
      "min": 30,
      "max": 600
    }
  },
  "defaultScriptDir": "scripts/1.0",
  "compatibility": [],
  "status": "Stable",
  "details": "Independent Stream",
  "disableUpstream": true,
  "providerVersion": "1.0.0",
  "contractVersion": 2,
  "controls": [
    {
      "id": "model",
      "type": "select",
      "label": "Model",
      "icon": "🤖",
      "placement": "bar",
      "order": 10,
      "dynamic": true,
      "listScript": "listModels",
      "setScript": "setModel",
      "readFrom": "model"
    },
    {
      "id": "mode",
      "type": "select",
      "label": "Mode",
      "icon": "🧭",
      "placement": "bar",
      "order": 20,
      "dynamic": true,
      "listScript": "listModes",
      "setScript": "setMode",
      "readFrom": "mode"
    },
    {
      "id": "new_session",
      "type": "action",
      "label": "New",
      "icon": "➕",
      "placement": "bar",
      "order": 80,
      "invokeScript": "newSession"
    }
  ]
}
