{
  "type": "codex",
  "name": "Codex",
  "category": "extension",
  "extensionId": "openai.chatgpt",
  "extensionIdPattern": "extensionId=openai\\.chat",
  "extensionIdPattern_flags": "i",
  "webviewMatchText": "openai.chat",
  "vscodeCommands": {
    "focusPanel": "openai-chatgpt.focus"
  },
  "settings": {
    "approvalAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Approval Notifications",
      "description": "Show notification when approval is needed"
    },
    "longGeneratingAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Long Generation Alert",
      "description": "Alert when generation takes too long"
    },
    "longGeneratingThresholdSec": {
      "type": "number",
      "default": 180,
      "public": true,
      "label": "Long Generation Threshold (sec)",
      "min": 30,
      "max": 600
    }
  },
  "defaultScriptDir": "scripts/1.0",
  "compatibility": [],
  "status": "Stable",
  "details": "Independent Stream"
}
