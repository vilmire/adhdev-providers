{
  "type": "claude-code-vscode",
  "name": "Claude Code (VS Code)",
  "category": "extension",
  "extensionId": "anthropic.claude-code",
  "extensionIdPattern": "extensionId=anthropic(\\.|%2[eE])claude-code|anthropic\\.claude-code",
  "extensionIdPattern_flags": "i",
  "vscodeCommands": {
    "focusPanel": "claude-vscode.sidebar.open"
  },
  "settings": {
    "approvalAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Approval Notifications",
      "description": "Show notification when approval is needed"
    },
    "longGeneratingAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Long Generation Alert",
      "description": "Alert when generation takes too long"
    },
    "longGeneratingThresholdSec": {
      "type": "number",
      "default": 180,
      "public": true,
      "label": "Long Generation Threshold (sec)",
      "min": 30,
      "max": 600
    }
  },
  "controls": [
    {
      "id": "model",
      "type": "select",
      "label": "Model",
      "icon": "🤖",
      "placement": "bar",
      "order": 10,
      "dynamic": true,
      "listScript": "listModels",
      "setScript": "setModelGui",
      "readFrom": "model"
    },
    {
      "id": "effort",
      "type": "select",
      "label": "Effort",
      "icon": "⚡",
      "placement": "bar",
      "order": 20,
      "options": [
        { "value": "low", "label": "Low" },
        { "value": "medium", "label": "Medium" },
        { "value": "high", "label": "High" },
        { "value": "max", "label": "Max" }
      ],
      "setScript": "setEffort",
      "readFrom": "effort"
    },
    {
      "id": "mode",
      "type": "select",
      "label": "Mode",
      "icon": "✏️",
      "placement": "bar",
      "order": 25,
      "dynamic": true,
      "listScript": "listModes",
      "setScript": "setMode",
      "readFrom": "mode"
    },
    {
      "id": "thinking",
      "type": "toggle",
      "label": "Thinking",
      "icon": "🧠",
      "placement": "bar",
      "order": 30,
      "setScript": "setThinking",
      "readFrom": "thinking"
    },
    {
      "id": "usage",
      "type": "action",
      "label": "Usage",
      "icon": "📊",
      "placement": "bar",
      "order": 40,
      "invokeScript": "requestUsage",
      "resultDisplay": "none"
    }
  ],
  "defaultScriptDir": "scripts/1.0",
  "compatibility": [],
  "status": "Unverified",
  "details": "Anthropic Claude Code sidebar webview — heuristics from Codex/Cline iframe + Antigravity input/markdown patterns; tune against live DOM via DevServer"
}
