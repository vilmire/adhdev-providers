{
  "type": "claude-code-vscode",
  "name": "Claude Code (VS Code)",
  "category": "extension",
  "extensionId": "anthropic.claude-code",
  "extensionIdPattern": "extensionId=anthropic(\\.|%2[eE])claude-code|anthropic\\.claude-code",
  "extensionIdPattern_flags": "i",
  "vscodeCommands": {
    "focusPanel": "claude-vscode.sidebar.open"
  },
  "settings": {
    "approvalAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Approval Notifications",
      "description": "Show notification when approval is needed"
    },
    "longGeneratingAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Long Generation Alert",
      "description": "Alert when generation takes too long"
    },
    "longGeneratingThresholdSec": {
      "type": "number",
      "default": 180,
      "public": true,
      "label": "Long Generation Threshold (sec)",
      "min": 30,
      "max": 600
    }
  },
  "approvalPositiveHints": [
    "yes",
    "allow once",
    "approve",
    "accept",
    "continue",
    "run",
    "proceed",
    "confirm",
    "save",
    "allow",
    "always allow"
  ],
  "controls": [
    {
      "id": "model",
      "type": "select",
      "label": "Model",
      "icon": "\ud83e\udd16",
      "placement": "bar",
      "order": 10,
      "dynamic": true,
      "listScript": "listModels",
      "setScript": "setModelGui",
      "readFrom": "model"
    },
    {
      "id": "effort",
      "type": "select",
      "label": "Effort",
      "icon": "\u26a1",
      "placement": "bar",
      "order": 20,
      "options": [
        {
          "value": "low",
          "label": "Low"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "high",
          "label": "High"
        },
        {
          "value": "max",
          "label": "Max"
        }
      ],
      "setScript": "setEffort",
      "readFrom": "effort"
    },
    {
      "id": "mode",
      "type": "select",
      "label": "Mode",
      "icon": "\u270f\ufe0f",
      "placement": "bar",
      "order": 25,
      "dynamic": true,
      "listScript": "listModes",
      "setScript": "setMode",
      "readFrom": "mode"
    },
    {
      "id": "thinking",
      "type": "toggle",
      "label": "Thinking",
      "icon": "\ud83e\udde0",
      "placement": "bar",
      "order": 30,
      "setScript": "setThinking",
      "readFrom": "thinking"
    },
    {
      "id": "usage",
      "type": "action",
      "label": "Usage",
      "icon": "\ud83d\udcca",
      "placement": "bar",
      "order": 40,
      "invokeScript": "requestUsage",
      "resultDisplay": "none"
    }
  ],
  "defaultScriptDir": "scripts/1.0",
  "compatibility": [],
  "status": "Unverified",
  "details": "Anthropic Claude Code sidebar webview \u2014 heuristics from Codex/Cline iframe + Antigravity input/markdown patterns; tune against live DOM via DevServer",
  "providerVersion": "1.0.0",
  "contractVersion": 2,
  "capabilities": {
    "input": {
      "multipart": false,
      "mediaTypes": [
        "text"
      ]
    },
    "output": {
      "richContent": false,
      "mediaTypes": [
        "text"
      ]
    },
    "controls": {
      "typedResults": true
    }
  }
}
