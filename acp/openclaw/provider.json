{
  "type": "openclaw-acp",
  "name": "OpenClaw (ACP)",
  "category": "acp",
  "displayName": "OpenClaw",
  "icon": "\ud83e\udd9e",
  "install": "See https://docs.openclaw.ai/cli/",
  "spawn": {
    "command": "openclaw",
    "args": [
      "acp"
    ],
    "shell": false
  },
  "auth": [
    {
      "type": "agent",
      "id": "openclaw",
      "name": "OpenClaw Auth",
      "description": "Authenticate with OpenClaw account"
    }
  ],
  "settings": {
    "autoApprove": {
      "type": "boolean",
      "default": false,
      "public": true,
      "label": "Auto Approve",
      "description": "Automatically approve all tool calls without user confirmation"
    },
    "approvalAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Approval Alerts",
      "description": "Show notification when agent requires approval"
    },
    "longGeneratingAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Long Generation Alert",
      "description": "Alert when generation takes too long"
    },
    "longGeneratingThresholdSec": {
      "type": "number",
      "default": 180,
      "public": true,
      "label": "Long Generation Threshold (sec)",
      "min": 30,
      "max": 600
    }
  },
  "providerVersion": "1.0.0",
  "contractVersion": 2,
  "capabilities": {
    "input": {
      "multipart": false,
      "mediaTypes": [
        "text"
      ]
    },
    "output": {
      "richContent": false,
      "mediaTypes": [
        "text"
      ]
    },
    "controls": {
      "typedResults": false
    }
  }
}
