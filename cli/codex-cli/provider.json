{
  "type": "codex-cli",
  "name": "Codex CLI",
  "category": "cli",
  "aliases": [
    "codex"
  ],
  "icon": "\ud83e\udde0",
  "displayName": "Codex CLI",
  "settings": {
    "notifications": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Notifications",
      "description": "Display notifications on state changes"
    },
    "autoApprove": {
      "type": "boolean",
      "default": false,
      "public": true,
      "label": "Auto Approve",
      "description": "Automatically approve all tool calls without user confirmation"
    },
    "approvalAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Approval Notifications",
      "description": "Show notification when approval is needed"
    },
    "longGeneratingAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Long Generation Alert",
      "description": "Alert when generation takes too long"
    },
    "longGeneratingThresholdSec": {
      "type": "number",
      "default": 180,
      "public": true,
      "label": "Long Generation Threshold (sec)",
      "min": 30,
      "max": 600
    }
  },
  "binary": "codex",
  "sendDelayMs": 1200,
  "sendKey": "\r\n",
  "submitStrategy": "wait_for_echo",
  "timeouts": {
    "idleFinishConfirm": 5000,
    "statusActivityHold": 5000
  },
  "spawn": {
    "command": "codex",
    "args": [
      "--dangerously-bypass-approvals-and-sandbox"
    ],
    "shell": false,
    "env": {}
  },
  "patterns": {
    "prompt": [
      {
        "source": "To get started, describe a task or try one of these commands",
        "flags": "i"
      },
      {
        "source": "^>\\s*$",
        "flags": "m"
      }
    ],
    "generating": [
      {
        "source": "Working \\(\\d+s",
        "flags": "i"
      }
    ],
    "approval": [
      {
        "source": "Always approve this session",
        "flags": "i"
      },
      {
        "source": "Approve and run now",
        "flags": "i"
      },
      {
        "source": "Allow command\\?",
        "flags": "i"
      }
    ],
    "ready": []
  },
  "resume": {
    "supported": true,
    "stopStrategy": "command",
    "stopCommand": "exit",
    "shutdownGraceMs": 4000,
    "sessionIdFormat": "uuid",
    "resumeSessionArgs": [
      "resume",
      "{{id}}"
    ],
    "resumeArgs": [
      "resume",
      "--last"
    ]
  },
  "canonicalHistory": {
    "format": "codex-jsonl",
    "watchPath": "~/.codex/sessions/**/*.jsonl",
    "mode": "native-source"
  },
  "compatibility": [
    {
      "ideVersion": ">=0.42.0",
      "scriptDir": "scripts/1.0"
    }
  ],
  "defaultScriptDir": "scripts/1.0",
  "status": "Stable",
  "details": "Terminal only",
  "providerVersion": "1.0.0",
  "contractVersion": 2,
  "capabilities": {
    "input": {
      "multipart": false,
      "mediaTypes": [
        "text"
      ]
    },
    "output": {
      "richContent": false,
      "mediaTypes": [
        "text"
      ]
    },
    "controls": {
      "typedResults": true
    }
  },
  "controls": [
    {
      "id": "model",
      "type": "display",
      "label": "Model",
      "icon": "\ud83e\udd16",
      "placement": "bar",
      "order": 10,
      "readFrom": "model"
    },
    {
      "id": "reasoning",
      "type": "display",
      "label": "Reasoning",
      "icon": "\ud83e\udde0",
      "placement": "bar",
      "order": 20,
      "readFrom": "reasoning"
    },
    {
      "id": "fast",
      "type": "toggle",
      "label": "Fast",
      "icon": "\u26a1",
      "placement": "bar",
      "order": 30,
      "defaultValue": false,
      "setScript": "setFast",
      "readFrom": "fast"
    },
    {
      "id": "model_picker",
      "type": "action",
      "label": "Model",
      "icon": "\u2318",
      "placement": "bar",
      "order": 40,
      "invokeScript": "openModelPicker"
    }
  ]
}
