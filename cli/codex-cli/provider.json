{
  "type": "codex-cli",
  "name": "Codex CLI",
  "category": "cli",
  "aliases": [
    "codex"
  ],
  "icon": "🧠",
  "displayName": "Codex CLI",
  "settings": {
    "notifications": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Notifications",
      "description": "Display notifications on state changes"
    },
    "autoApprove": {
      "type": "boolean",
      "default": false,
      "public": true,
      "label": "Auto Approve",
      "description": "Automatically approve all tool calls without user confirmation"
    },
    "approvalAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Approval Notifications",
      "description": "Show notification when approval is needed"
    },
    "longGeneratingAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Long Generation Alert",
      "description": "Alert when generation takes too long"
    },
    "longGeneratingThresholdSec": {
      "type": "number",
      "default": 180,
      "public": true,
      "label": "Long Generation Threshold (sec)",
      "min": 30,
      "max": 600
    }
  },
  "binary": "codex",
  "sendDelayMs": 1200,
  "sendKey": "\r",
  "spawn": {
    "command": "codex",
    "args": [],
    "shell": false,
    "env": {}
  },
  "patterns": {
    "prompt": [
      {
        "source": "To get started, describe a task or try one of these commands",
        "flags": "i"
      },
      {
        "source": "^>\\s*$",
        "flags": "m"
      }
    ],
    "generating": [
      {
        "source": "Working \\(\\d+s",
        "flags": "i"
      }
    ],
    "approval": [
      {
        "source": "Always approve this session",
        "flags": "i"
      },
      {
        "source": "Approve and run now",
        "flags": "i"
      },
      {
        "source": "Allow command\\?",
        "flags": "i"
      }
    ],
    "ready": []
  },
  "resume": {
    "supported": true,
    "stopStrategy": "command",
    "stopCommand": "exit",
    "shutdownGraceMs": 4000,
    "resumeArgs": [
      "resume",
      "--last"
    ]
  },
  "compatibility": [
    {
      "ideVersion": ">=0.42.0",
      "scriptDir": "scripts/1.0"
    }
  ],
  "defaultScriptDir": "scripts/1.0",
  "status": "Stable",
  "details": "Terminal only"
}
