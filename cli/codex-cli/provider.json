{
  "type": "codex-cli",
  "name": "Codex CLI",
  "category": "cli",
  "aliases": [
    "codex"
  ],
  "icon": "🧠",
  "displayName": "Codex CLI",
  "settings": {
    "mode": {
      "type": "select",
      "default": "terminal",
      "public": true,
      "label": "표시 모드",
      "options": [
        "terminal",
        "chat"
      ]
    },
    "notifications": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "알림"
    },
    "autoApprove": {
      "type": "boolean",
      "default": false,
      "public": true,
      "label": "Auto Approve",
      "description": "Automatically approve all tool calls without user confirmation"
    },
    "approvalAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Approval Notifications",
      "description": "Show notification when approval is needed"
    },
    "longGeneratingAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Long Generation Alert",
      "description": "Alert when generation takes too long"
    },
    "longGeneratingThresholdSec": {
      "type": "number",
      "default": 180,
      "public": true,
      "label": "Long Generation Threshold (sec)",
      "min": 30,
      "max": 600
    }
  },
  "binary": "codex",
  "spawn": {
    "command": "codex",
    "args": [
      "--full-auto"
    ],
    "shell": false,
    "env": {}
  },
  "patterns": {
    "prompt": [
      {},
      {},
      {}
    ],
    "generating": [
      {},
      {},
      {}
    ],
    "approval": [
      {},
      {},
      {},
      {},
      {}
    ],
    "ready": [
      {},
      {}
    ]
  }
}
