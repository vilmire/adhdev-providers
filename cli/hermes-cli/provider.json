{
  "type": "hermes-cli",
  "name": "Hermes Agent",
  "category": "cli",
  "transcriptAuthority": "provider",
  "transcriptContext": "tail",
  "aliases": [
    "hermes",
    "hermes-agent"
  ],
  "icon": "\u2695",
  "displayName": "Hermes Agent",
  "settings": {
    "notifications": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Notifications",
      "description": "Display notifications on state changes"
    },
    "autoApprove": {
      "type": "boolean",
      "default": false,
      "public": true,
      "label": "Auto Approve",
      "description": "Automatically approve tool execution without prompt"
    },
    "approvalAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Approval Notifications",
      "description": "Show notification when approval is needed"
    },
    "longGeneratingAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Long Generation Alert",
      "description": "Alert when generation takes too long"
    },
    "longGeneratingThresholdSec": {
      "type": "number",
      "default": 180,
      "public": true,
      "label": "Long Generation Threshold (sec)",
      "min": 30,
      "max": 600
    }
  },
  "controls": [
    {
      "id": "provider",
      "type": "select",
      "label": "Provider",
      "icon": "\ud83c\udf10",
      "placement": "bar",
      "order": 10,
      "defaultValue": "auto",
      "options": [
        {
          "value": "auto",
          "label": "Auto"
        },
        {
          "value": "openai-codex",
          "label": "OpenAI Codex"
        },
        {
          "value": "openrouter",
          "label": "OpenRouter"
        },
        {
          "value": "nous",
          "label": "Nous"
        },
        {
          "value": "anthropic",
          "label": "Anthropic"
        },
        {
          "value": "gemini",
          "label": "Gemini"
        },
        {
          "value": "copilot",
          "label": "Copilot"
        },
        {
          "value": "copilot-acp",
          "label": "Copilot ACP"
        },
        {
          "value": "huggingface",
          "label": "Hugging Face"
        },
        {
          "value": "zai",
          "label": "Z.AI"
        },
        {
          "value": "kimi-coding",
          "label": "Kimi Coding"
        },
        {
          "value": "minimax",
          "label": "MiniMax"
        },
        {
          "value": "minimax-cn",
          "label": "MiniMax CN"
        },
        {
          "value": "kilocode",
          "label": "Kilocode"
        },
        {
          "value": "xiaomi",
          "label": "Xiaomi"
        }
      ],
      "setScript": "setProvider",
      "readFrom": "provider"
    },
    {
      "id": "reasoning",
      "type": "select",
      "label": "Reasoning",
      "icon": "\ud83e\udde0",
      "placement": "bar",
      "order": 20,
      "defaultValue": "none",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "minimal",
          "label": "Minimal"
        },
        {
          "value": "low",
          "label": "Low"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "high",
          "label": "High"
        },
        {
          "value": "xhigh",
          "label": "XHigh"
        }
      ],
      "setScript": "setReasoning",
      "readFrom": "reasoning"
    },
    {
      "id": "yolo",
      "type": "toggle",
      "label": "YOLO",
      "icon": "\u26a0",
      "placement": "bar",
      "order": 30,
      "defaultValue": false,
      "setScript": "setYolo",
      "readFrom": "yolo"
    },
    {
      "id": "new_session",
      "type": "action",
      "label": "New",
      "icon": "\u271a",
      "placement": "bar",
      "hidden": true,
      "order": 70,
      "invokeScript": "newSession",
      "confirmTitle": "Start a new Hermes session?",
      "confirmMessage": "This clears the current dashboard transcript and switches Hermes to a fresh session.",
      "confirmLabel": "Start new session"
    },
    {
      "id": "undo_last",
      "type": "action",
      "label": "Undo",
      "icon": "\u21b6",
      "placement": "bar",
      "order": 75,
      "invokeScript": "undoLast",
      "confirmTitle": "Undo the last Hermes exchange?",
      "confirmMessage": "This asks Hermes to remove the most recent exchange. Dashboard transcript updates may lag briefly.",
      "confirmLabel": "Send undo"
    },
    {
      "id": "retry_last",
      "type": "action",
      "label": "Retry",
      "icon": "\u21ba",
      "placement": "bar",
      "order": 80,
      "invokeScript": "retryLast",
      "confirmTitle": "Retry the last Hermes turn?",
      "confirmMessage": "This asks Hermes to rerun the most recent prompt in the current session.",
      "confirmLabel": "Retry turn"
    }
  ],
  "binary": "hermes",
  "versionCommand": "hermes version",
  "sendDelayMs": 500,
  "sendKey": "\r",
  "allowInputDuringGeneration": true,
  "spawn": {
    "command": "hermes",
    "args": [
      "chat"
    ],
    "shell": true,
    "env": {}
  },
  "timeouts": {
    "generatingIdle": 20000,
    "idleFinish": 20000,
    "idleFinishConfirm": 5000,
    "statusActivityHold": 5000
  },
  "resume": {
    "supported": true,
    "stopStrategy": "command",
    "stopCommand": "/quit",
    "shutdownGraceMs": 4000,
    "sessionIdFormat": "string",
    "resumeSessionArgs": [
      "--resume",
      "{{id}}"
    ],
    "resumeArgs": [
      "--continue"
    ]
  },
  "patterns": {
    "prompt": [
      {
        "source": "Welcome to Hermes Agent! Type your message or /help for commands\\.",
        "flags": "i"
      },
      {
        "source": "^\u276f\\s*$",
        "flags": "m"
      }
    ],
    "generating": [
      {
        "source": "Initializing agent",
        "flags": "i"
      },
      {
        "source": "reasoning",
        "flags": "i"
      },
      {
        "source": "Enter to interrupt, Ctrl\\+C to cancel",
        "flags": "i"
      }
    ],
    "approval": [
      {
        "source": "Dangerous Command",
        "flags": "i"
      },
      {
        "source": "Allow once",
        "flags": "i"
      },
      {
        "source": "Allow for this session",
        "flags": "i"
      },
      {
        "source": "Add to permanent allowlist",
        "flags": "i"
      },
      {
        "source": "Deny",
        "flags": "i"
      }
    ],
    "ready": [
      {
        "source": "^\u276f\\s*$",
        "flags": "m"
      },
      {
        "source": "Type your message or /help for commands",
        "flags": "i"
      }
    ]
  },
  "approvalKeys": {
    "0": "\r",
    "1": "\u001b[B\r",
    "2": "\u001b[B\u001b[B\r",
    "3": "\u001b[B\u001b[B\u001b[B\r"
  },
  "compatibility": [
    {
      "ideVersion": ">=0.8.0",
      "scriptDir": "scripts/1.0"
    }
  ],
  "defaultScriptDir": "scripts/1.0",
  "status": "Beta",
  "details": "Terminal only",
  "providerVersion": "1.0.0",
  "contractVersion": 2,
  "capabilities": {
    "input": {
      "multipart": false,
      "mediaTypes": [
        "text"
      ]
    },
    "output": {
      "richContent": false,
      "mediaTypes": [
        "text"
      ]
    },
    "controls": {
      "typedResults": true
    }
  },
  "canonicalHistory": {
    "format": "hermes-json",
    "watchPath": "~/.hermes/sessions/session_{{sessionId}}.json",
    "mode": "native-source"
  }
}
