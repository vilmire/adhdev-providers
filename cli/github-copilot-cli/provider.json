{
  "type": "github-copilot-cli",
  "name": "GitHub Copilot CLI",
  "category": "cli",
  "aliases": [
    "gh-copilot"
  ],
  "icon": "🤖",
  "displayName": "GitHub Copilot CLI",
  "settings": {
    "mode": {
      "type": "select",
      "default": "chat",
      "public": true,
      "label": "Display Mode",
      "description": "terminal: Native PTY view, chat: Parsed message view",
      "options": [
        "terminal",
        "chat"
      ]
    }
  },
  "binary": "gh",
  "spawn": {
    "command": "gh",
    "args": ["copilot"],
    "shell": true,
    "env": {}
  },
  "compatibility": [
    {
      "ideVersion": ">=1.0.0",
      "scriptDir": "scripts/1.0"
    }
  ],
  "defaultScriptDir": "scripts/1.0"
}
