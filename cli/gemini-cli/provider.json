{
  "type": "gemini-cli",
  "name": "Gemini CLI",
  "category": "cli",
  "aliases": [
    "gemini"
  ],
  "icon": "♊",
  "displayName": "Gemini CLI",
  "settings": {
    "mode": {
      "type": "select",
      "default": "terminal",
      "public": true,
      "label": "Display Mode",
      "description": "terminal: Native PTY view, chat: Parsed message view",
      "options": [
        "terminal",
        "chat"
      ]
    },
    "notifications": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Notifications",
      "description": "Display notifications on state changes"
    },
    "autoApprove": {
      "type": "boolean",
      "default": false,
      "public": true,
      "label": "Auto Approve",
      "description": "Automatically approve all tool calls without user confirmation"
    },
    "approvalAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Approval Notifications",
      "description": "Show notification when approval is needed"
    },
    "longGeneratingAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Long Generation Alert",
      "description": "Alert when generation takes too long"
    },
    "longGeneratingThresholdSec": {
      "type": "number",
      "default": 180,
      "public": true,
      "label": "Long Generation Threshold (sec)",
      "min": 30,
      "max": 600
    }
  },
  "binary": "gemini",
  "spawn": {
    "command": "gemini",
    "args": [
      "--yolo"
    ],
    "shell": true,
    "env": {}
  },
  "patterns": {
    "prompt": [
      { "source": "\\?\\s*for\\s*shortcuts", "flags": "i" },
      { "source": "^>\\s*$", "flags": "m" },
      { "source": "[›❯]\\s*$", "flags": "m" },
      { "source": "sandbox", "flags": "i" },
      { "source": "Type your message", "flags": "i" }
    ],
    "generating": [
      { "source": "[\\u2800-\\u28ff]", "flags": "" },
      { "source": "[▀▄▌▐░▒▓█]", "flags": "" },
      { "source": "Thinking", "flags": "i" },
      { "source": "Generating", "flags": "i" },
      { "source": "esc to (cancel|interrupt|stop)", "flags": "i" }
    ],
    "approval": [
      { "source": "Allow\\s*once", "flags": "i" },
      { "source": "Always\\s*allow", "flags": "i" },
      { "source": "\\(y/n\\)", "flags": "i" },
      { "source": "\\[Y/n\\]", "flags": "i" },
      { "source": "Run\\s*this\\s*command", "flags": "i" },
      { "source": "Deny", "flags": "i" },
      { "source": "auto-?approve", "flags": "i" }
    ],
    "ready": [
      { "source": "\\?\\s*for\\s*shortcuts", "flags": "i" },
      { "source": "sandbox", "flags": "i" }
    ]
  },
  "approvalKeys": {
    "0": "y",
    "1": "a",
    "2": "n"
  }
}
