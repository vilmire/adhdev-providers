{
  "type": "cursor-cli",
  "name": "Cursor CLI",
  "category": "cli",
  "aliases": [
    "cursor"
  ],
  "icon": "\ud83e\udd16",
  "displayName": "Cursor CLI",
  "controls": [
    {
      "id": "model",
      "type": "select",
      "label": "Model",
      "icon": "🤖",
      "placement": "bar",
      "order": 10,
      "listScript": "listModels",
      "setScript": "setModel",
      "readFrom": "model"
    }
  ],
  "binary": "cursor",
  "versionCommand": "cursor agent about",
  "sendDelayMs": 500,
  "submitStrategy": "wait_for_echo",
  "spawn": {
    "command": "cursor",
    "args": [
      "agent"
    ],
    "shell": true,
    "env": {}
  },
  "resume": {
    "supported": true,
    "stopStrategy": "ctrl_c",
    "shutdownGraceMs": 4000,
    "sessionIdFormat": "uuid",
    "resumeSessionArgs": [
      "--resume",
      "{{id}}"
    ],
    "resumeArgs": [
      "--continue"
    ]
  },
  "compatibility": [
    {
      "ideVersion": ">=1.0.0",
      "scriptDir": "scripts/1.0"
    }
  ],
  "status": "Beta",
  "details": "Terminal only",
  "providerVersion": "1.0.0",
  "contractVersion": 2,
  "capabilities": {
    "input": {
      "multipart": false,
      "mediaTypes": [
        "text"
      ]
    },
    "output": {
      "richContent": false,
      "mediaTypes": [
        "text"
      ]
    },
    "controls": {
      "typedResults": true
    }
  }
}
