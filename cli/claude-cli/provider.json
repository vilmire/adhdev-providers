{
  "type": "claude-cli",
  "name": "Claude Code",
  "category": "cli",
  "aliases": [
    "claude",
    "claude-code"
  ],
  "icon": "🤖",
  "displayName": "Claude Code",
  "settings": {
    "notifications": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Notifications",
      "description": "Display notifications on state changes"
    },
    "autoApprove": {
      "type": "boolean",
      "default": false,
      "public": true,
      "label": "Auto Approve",
      "description": "Automatically approve tool execution without prompt"
    },
    "approvalAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Approval Notifications",
      "description": "Show notification when approval is needed"
    },
    "longGeneratingAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Long Generation Alert",
      "description": "Alert when generation takes too long"
    },
    "longGeneratingThresholdSec": {
      "type": "number",
      "default": 180,
      "public": true,
      "label": "Long Generation Threshold (sec)",
      "min": 30,
      "max": 600
    }
  },
  "binary": "claude",
  "sendDelayMs": 700,
  "submitStrategy": "immediate",
  "spawn": {
    "command": "claude",
    "args": [
      "--permission-mode",
      "acceptEdits"
    ],
    "shell": true,
    "env": {}
  },
  "patterns": {
    "prompt": [
      {
        "source": "Type your message",
        "flags": "i"
      },
      {
        "source": "for\\s*shortcuts",
        "flags": "i"
      },
      {
        "source": "\\?\\s*for\\s*help",
        "flags": "i"
      },
      {
        "source": "Press enter",
        "flags": "i"
      },
      {
        "source": "[›❯]\\s*$",
        "flags": "m"
      },
      {
        "source": "medium\\s+·\\s+/effort",
        "flags": "i"
      }
    ],
    "generating": [
      {
        "source": "[\\u2800-\\u28ff]",
        "flags": ""
      },
      {
        "source": "esc to (cancel|interrupt|stop)",
        "flags": "i"
      },
      {
        "source": "generating\\.\\.\\.",
        "flags": "i"
      },
      {
        "source": "Claude is (?:thinking|processing|working)",
        "flags": "i"
      },
      {
        "source": "Flummoxing",
        "flags": "i"
      },
      {
        "source": "Finagling",
        "flags": "i"
      },
      {
        "source": "Scurrying",
        "flags": "i"
      },
      {
        "source": "Bloviating",
        "flags": "i"
      },
      {
        "source": "Whatchamacallit(?:ing)?",
        "flags": "i"
      },
      {
        "source": "(Thinking|Processing|Working|Analyzing|Planning|Drafting|Synthesizing|Inspecting|Reading|Searching)…?",
        "flags": "i"
      }
    ],
    "approval": [
      {
        "source": "Allow\\s*once",
        "flags": "i"
      },
      {
        "source": "Always\\s*allow",
        "flags": "i"
      },
      {
        "source": "\\(y/n\\)",
        "flags": "i"
      },
      {
        "source": "\\[Y/n\\]",
        "flags": "i"
      }
    ],
    "ready": [
      {
        "source": "for\\s*shortcuts",
        "flags": "i"
      },
      {
        "source": "[›❯]\\s*$",
        "flags": "m"
      }
    ],
    "dialog": [
      {
        "source": "Quick safety check",
        "flags": "i"
      },
      {
        "source": "Is this a project",
        "flags": "i"
      },
      {
        "source": "Enter to confirm",
        "flags": "i"
      }
    ]
  },
  "approvalKeys": {
    "0": "1",
    "1": "2",
    "2": "3",
    "3": "4"
  },
  "resume": {
    "supported": true,
    "stopStrategy": "command",
    "stopCommand": "exit",
    "shutdownGraceMs": 4000,
    "sessionIdFormat": "uuid",
    "newSessionArgs": [
      "--session-id",
      "{{id}}"
    ],
    "resumeSessionArgs": [
      "--resume",
      "{{id}}"
    ],
    "resumeArgs": [
      "--continue"
    ]
  },
  "compatibility": [
    {
      "ideVersion": ">=2.1.0",
      "scriptDir": "scripts/1.0"
    }
  ],
  "defaultScriptDir": "scripts/1.0",
  "status": "Stable",
  "details": "Terminal only",
  "disableUpstream": true
}