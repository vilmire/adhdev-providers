{
  "type": "claude-cli",
  "name": "Claude Code",
  "category": "cli",
  "aliases": [
    "claude",
    "claude-code"
  ],
  "icon": "\ud83e\udd16",
  "displayName": "Claude Code",
  "settings": {
    "notifications": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Notifications",
      "description": "Display notifications on state changes"
    },
    "autoApprove": {
      "type": "boolean",
      "default": false,
      "public": true,
      "label": "Auto Approve",
      "description": "Automatically approve tool execution without prompt"
    },
    "approvalAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Approval Notifications",
      "description": "Show notification when approval is needed"
    },
    "longGeneratingAlert": {
      "type": "boolean",
      "default": true,
      "public": true,
      "label": "Long Generation Alert",
      "description": "Alert when generation takes too long"
    },
    "longGeneratingThresholdSec": {
      "type": "number",
      "default": 180,
      "public": true,
      "label": "Long Generation Threshold (sec)",
      "min": 30,
      "max": 600
    }
  },
  "controls": [
    {
      "id": "model",
      "type": "select",
      "label": "Model",
      "icon": "\ud83e\udd16",
      "placement": "bar",
      "order": 10,
      "dynamic": true,
      "listScript": "listModels",
      "setScript": "setModel",
      "readFrom": "model"
    },
    {
      "id": "effort",
      "type": "select",
      "label": "Effort",
      "icon": "\u26a1",
      "placement": "bar",
      "order": 20,
      "options": [
        {
          "value": "low",
          "label": "Low"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "high",
          "label": "High"
        },
        {
          "value": "max",
          "label": "Max"
        }
      ],
      "setScript": "setEffort",
      "readFrom": "effort"
    }
  ],
  "binary": "claude",
  "sendDelayMs": 700,
  "submitStrategy": "wait_for_echo",
  "timeouts": {
    "idleFinishConfirm": 5000,
    "statusActivityHold": 5000
  },
  "spawn": {
    "command": "claude",
    "args": [
      "--permission-mode",
      "acceptEdits"
    ],
    "shell": true,
    "env": {}
  },
  "patterns": {
    "prompt": [
      {
        "source": "Type your message",
        "flags": "i"
      },
      {
        "source": "for\\s*shortcuts",
        "flags": "i"
      },
      {
        "source": "\\?\\s*for\\s*help",
        "flags": "i"
      },
      {
        "source": "Press enter",
        "flags": "i"
      },
      {
        "source": "[\u203a\u276f]\\s*$",
        "flags": "m"
      },
      {
        "source": "medium\\s+\u00b7\\s+/effort",
        "flags": "i"
      }
    ],
    "generating": [
      {
        "source": "[\\u2800-\\u28ff]",
        "flags": ""
      },
      {
        "source": "esc to (cancel|interrupt|stop)",
        "flags": "i"
      },
      {
        "source": "generating\\.\\.\\.",
        "flags": "i"
      },
      {
        "source": "Claude is (?:thinking|processing|working)",
        "flags": "i"
      },
      {
        "source": "Flummoxing",
        "flags": "i"
      },
      {
        "source": "Finagling",
        "flags": "i"
      },
      {
        "source": "Scurrying",
        "flags": "i"
      },
      {
        "source": "Bloviating",
        "flags": "i"
      },
      {
        "source": "Whatchamacallit(?:ing)?",
        "flags": "i"
      },
      {
        "source": "(Thinking|Processing|Working|Analyzing|Planning|Drafting|Synthesizing|Inspecting|Reading|Searching)\u2026?",
        "flags": "i"
      }
    ],
    "approval": [
      {
        "source": "Allow\\s*once",
        "flags": "i"
      },
      {
        "source": "Always\\s*allow",
        "flags": "i"
      },
      {
        "source": "\\(y/n\\)",
        "flags": "i"
      },
      {
        "source": "\\[Y/n\\]",
        "flags": "i"
      }
    ],
    "ready": [
      {
        "source": "for\\s*shortcuts",
        "flags": "i"
      },
      {
        "source": "[\u203a\u276f]\\s*$",
        "flags": "m"
      }
    ],
    "dialog": [
      {
        "source": "Quick safety check",
        "flags": "i"
      },
      {
        "source": "Is this a project",
        "flags": "i"
      },
      {
        "source": "Enter to confirm",
        "flags": "i"
      }
    ]
  },
  "approvalKeys": {
    "0": "1",
    "1": "2",
    "2": "3",
    "3": "4"
  },
  "resume": {
    "supported": true,
    "stopStrategy": "command",
    "stopCommand": "exit",
    "shutdownGraceMs": 4000,
    "sessionIdFormat": "uuid",
    "newSessionArgs": [
      "--session-id",
      "{{id}}"
    ],
    "resumeSessionArgs": [
      "--resume",
      "{{id}}"
    ],
    "resumeArgs": [
      "--continue"
    ]
  },
  "compatibility": [
    {
      "ideVersion": ">=2.1.0",
      "scriptDir": "scripts/1.0"
    }
  ],
  "defaultScriptDir": "scripts/1.0",
  "status": "Stable",
  "details": "Terminal only",
  "disableUpstream": true,
  "providerVersion": "1.0.0",
  "contractVersion": 2,
  "capabilities": {
    "input": {
      "multipart": false,
      "mediaTypes": [
        "text"
      ]
    },
    "output": {
      "richContent": false,
      "mediaTypes": [
        "text"
      ]
    },
    "controls": {
      "typedResults": true
    }
  },
  "meshCoordinator": {
    "supported": true,
    "mcpConfig": {
      "mode": "auto_import",
      "format": "claude_mcp_json",
      "path": ".mcp.json",
      "serverName": "adhdev-mesh"
    }
  },
  "canonicalHistory": {
    "format": "claude-jsonl",
    "watchPath": "~/.claude/projects/**/*.jsonl",
    "mode": "native-source",
    "scripts": {
      "readSession": "readNativeHistory",
      "listSessions": "listNativeHistory"
    }
  }
}
